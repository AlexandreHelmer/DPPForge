# Production Environment Variables Template
DEBUG=False
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@localhost:5432/dpp_db

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Google OAuth
SOCIALACCOUNT_PROVIDERS_GOOGLE_CLIENT_ID=your-production-google-client-id
SOCIALACCOUNT_PROVIDERS_GOOGLE_SECRET=your-production-google-secret

# Email Backend (SMTP for production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Site Configuration
SITE_ID=1
FRONTEND_URL=https://yourdomain.com
